<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notifetch_dark_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/notifetch_dark_surface"
        app:titleTextColor="@color/notifetch_text_primary"
        app:navigationIconTint="@color/notifetch_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="72sp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Notification Access"
                android:textColor="@color/notifetch_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/notifetch_dark_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/notifetch_amber"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_permission_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❌ Notification Access Required"
                        android:textColor="@color/notifetch_error"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_permission_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/permission_description"
                        android:textColor="@color/notifetch_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Why we need this -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/notifetch_dark_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="How It Works"
                        android:textColor="@color/notifetch_amber"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="1️⃣ NotiFetch listens for notifications from delivery apps\n2️⃣ Captures order details (pickup, dropoff, payout)\n3️⃣ Shows everything in one unified dashboard\n4️⃣ No login credentials needed — ever!"
                        android:textColor="@color/notifetch_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Privacy Note -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/notifetch_dark_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 Your Privacy"
                        android:textColor="@color/notifetch_amber"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• Notifications are processed on your device\n• Only delivery app notifications are captured\n• No personal messages or other apps are read\n• Data is sent securely to the NotiFetch backend\n• You can delete all data anytime"
                        android:textColor="@color/notifetch_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Enable Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enable_notification_access"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/notifetch_amber"
                android:text="Enable Notification Access"
                android:textColor="@color/notifetch_dark_bg"
                android:textSize="16sp"
                app:cornerRadius="16dp" />

            <!-- Continue Button (shown after permission is granted) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/notifetch_amber"
                android:enabled="false"
                android:text="Continue to NotiFetch"
                android:textColor="@color/notifetch_dark_bg"
                android:textSize="16sp"
                app:cornerRadius="16dp" />

            <!-- Skip Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_skip"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Skip for now"
                android:textColor="@color/notifetch_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
