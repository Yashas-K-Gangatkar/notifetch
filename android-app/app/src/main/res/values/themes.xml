<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main NotiFetch Theme (Dark) -->
    <style name="Theme.NotiFetch" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color (amber) -->
        <item name="colorPrimary">@color/notifetch_amber</item>
        <item name="colorOnPrimary">@color/notifetch_dark_bg</item>
        <item name="colorPrimaryContainer">@color/notifetch_amber_dark</item>
        <item name="colorOnPrimaryContainer">@color/notifetch_amber_light</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/notifetch_dark_elevated</item>
        <item name="colorOnSecondary">@color/notifetch_text_primary</item>
        <item name="colorSecondaryContainer">@color/notifetch_dark_card</item>
        <item name="colorOnSecondaryContainer">@color/notifetch_text_primary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/notifetch_dark_bg</item>
        <item name="colorOnBackground">@color/notifetch_text_primary</item>
        <item name="colorSurface">@color/notifetch_dark_surface</item>
        <item name="colorOnSurface">@color/notifetch_text_primary</item>
        <item name="colorSurfaceVariant">@color/notifetch_dark_card</item>
        <item name="colorOnSurfaceVariant">@color/notifetch_text_secondary</item>

        <!-- Error -->
        <item name="colorError">@color/notifetch_error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/notifetch_dark_surface</item>
        <item name="android:navigationBarColor">@color/notifetch_dark_surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/notifetch_text_primary</item>
        <item name="android:textColorSecondary">@color/notifetch_text_secondary</item>
        <item name="android:textColorHint">@color/notifetch_text_disabled</item>
    </style>

    <!-- Bottom Navigation Color Selector -->
    <style name="BottomNavColor">
        <item name="android:textColor">@color/bottom_nav_color</item>
    </style>
</resources>
