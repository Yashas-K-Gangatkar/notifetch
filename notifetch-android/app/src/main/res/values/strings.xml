    <!-- ============ Permission screen ============ -->
    <string name="permission_title">Enable Notification Access</string>
    <string name="permission_description">NotiFetch needs notification access to capture delivery partner notifications and help you track your earnings.</string>
    <string name="permission_description_long">NotiFetch needs notification access to capture delivery partner notifications and help you track your earnings across all platforms.</string>
    <string name="permission_step_1">Tap the \"Open Settings\" button below</string>
    <string name="permission_step_2">Find \"NotiFetch\" in the notification access list</string>
    <string name="permission_step_3">Toggle the switch ON to allow notification access</string>
    <string name="permission_step_4">Confirm by tapping \"Allow\" on the dialog</string>
    <string name="permission_step_5">Return to NotiFetch — you\'re all set!</string>
    <string name="permission_open_settings">Open Notification Settings</string>
    <string name="permission_alt_settings">Alternative: App Notification Settings</string>
    <string name="permission_privacy_note">NotiFetch only reads notifications from delivery partner apps. Your personal messages and other app notifications are never accessed.</string>
    <string name="permission_enabled">Notification access is enabled! You\'re all set.</string>
    <string name="permission_setup_instructions">Setup Instructions</string>
    <string name="permission_what_we_read">What We Read</string>
    <string name="permission_what_we_read_desc">Only notifications from 55+ verified delivery partner/driver apps. We extract: title, text, order value, pickup/dropoff locations, and distance. This is data you can already see on your screen.</string>
    <string name="permission_what_we_never_access">What We NEVER Access</string>
    <string name="permission_what_we_never_access_desc">Banking apps, social media, personal messages, WhatsApp, SMS, email, or any app not on our delivery partner list. We never store credentials, auth tokens, or raw notification extras.</string>
    <string name="permission_legal_notice">Legal Notice</string>
    <string name="permission_legal_notice_desc">NotiFetch is not affiliated with any delivery platform. Platform names are used for identification only (you can customize them). You are responsible for complying with each platform\'s terms of service. By enabling notification access, you consent to data collection as described in our Privacy Policy.</string>

    <!-- ============ Consent screen ============ -->
    <string name="consent_before_you_begin">Before You Begin</string>
    <string name="consent_intro">NotiFetch needs your informed consent before collecting any data. Please read and accept each statement below.</string>
    <string name="consent_data_collection_title">Data Collection</string>
    <string name="consent_data_collection_desc">NotiFetch reads notifications from delivery partner/driver apps using Android\'s NotificationListenerService API. We collect ONLY:\n• Notification title and text\n• Order value, pickup/dropoff locations, distance\n• Platform name and timestamp\n\nWe NEVER access: banking, social media, personal messages, or any other app notifications.\n\nWe NEVER store: raw notification extras, auth tokens, or data you cannot see in the notification shade.\n\nRetention: Data is stored locally on your device and auto-deleted after 30 days. You can delete it anytime.</string>
    <string name="consent_no_affiliation_title">No Affiliation</string>
    <string name="consent_no_affiliation_desc">NotiFetch is NOT affiliated with, endorsed by, or connected to any delivery platform (Swiggy, Zomato, Uber, DoorDash, Amazon, etc.). Platform names appear in the app for identification purposes only. You can customize any platform name to whatever you prefer.</string>
    <string name="consent_your_responsibility_title">Your Responsibility</string>
    <string name="consent_your_responsibility_desc">You are solely responsible for complying with the terms of service of each delivery platform you use. NotiFetch is a personal notification management tool. We do not encourage or support any violation of platform terms. If a platform prohibits using third-party notification tools, you must decide whether to use NotiFetch for that platform.\n\nIMPORTANT: Delivery platforms CAN detect that a notification listener is active on your device. This is an Android system feature and cannot be hidden. Some platforms may warn or deactivate drivers who use notification reading tools. By continuing, you acknowledge this risk.</string>
    <string name="consent_privacy_policy_title">Privacy Policy &amp; Your Rights</string>
    <string name="consent_privacy_policy_desc">You have the right to delete all your data at any time, export your data, and revoke consent. Data is retained for 30 days and then automatically deleted. We follow India DPDP Act 2023 and EU GDPR standards. By continuing, you agree to our Privacy Policy and Terms of Service.</string>
    <string name="consent_read_privacy_policy">Read Privacy Policy &amp; Terms</string>
    <string name="consent_i_agree_continue">I Agree — Continue</string>
    <string name="consent_decline_exit">Decline — Exit App</string>

