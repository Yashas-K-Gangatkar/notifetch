<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Remove all advertising-related permissions injected by transitive dependencies (Firebase Analytics, Play Services) -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:name=".NotiFetchApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NotiFetch"
        tools:targetApi="35">

        <!-- Remove AdServices config injected by Firebase Analytics -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            tools:node="remove" />
        <uses-library
            android:name="android.ext.adservices"
            tools:node="remove" />

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NotiFetch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification Listener Service -->
        <service
            android:name=".notification.NotiFetchListenerService"
            android:exported="true"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <!-- FIX: Removed default_filter_types and default_rule_types metadata.
                 These OEM-specific metadata values were causing inconsistent behavior:
                 - On some Samsung/Xiaomi devices, they restricted which notifications the listener received
                 - Users reported only Zomato notifications appearing, not other apps
                 - The pipe-separated syntax (conversations|alerting|ongoing|silent) is not universally supported
                 - Some OEMs ignore these entirely and use their own filtering logic
                 
                 By removing these metadata entries, the listener will receive ALL notifications
                 and filter programmatically in onNotificationPosted() against Constants.ALL_PACKAGES.
                 This ensures consistent behavior across all Android devices and OEMs.
            -->
        </service>

        <!-- Firebase Messaging Service -->
        <service
            android:name=".firebase.NotiFetchMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- WorkManager initialization -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
