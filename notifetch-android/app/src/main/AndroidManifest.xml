<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Remove all advertising-related permissions injected by transitive dependencies (Firebase Analytics, Play Services) -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- v2.9.11: Request battery optimization exemption so NotificationListenerService
         isn't killed on Xiaomi/OPPO/Vivo/Samsung devices. User must grant via system dialog. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- v2.9.66: RESTORED foreground service permissions (started from MainActivity now, no crash) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         v2.9.7 — Package Visibility (Android 11+ / API 30+)

         THE BUG: When user tapped "Open Zomato" in NotiFetch, they were taken to
         the Play Store instead of the Zomato app.

         ROOT CAUSE: Android 11+ restricts which packages an app can see. Without
         a <queries> declaration, these APIs return NULL for all third-party apps:
           - PackageManager.getLaunchIntentForPackage()
           - PackageManager.resolveActivity()
         The "Open App" button's fallback logic (Strategy 4) then opened Play Store.

         THE FIX: Declare <queries> so the system lets NotiFetch see all delivery
         apps. Two query types:

         1. <intent> query for the LAUNCHER action — lets us see ANY app that has
            a launcher icon. This is the broadest, Play-Store-policy-compliant way.
            It's what we need for getLaunchIntentForPackage() to work.

         2. <intent> query for VIEW https — lets us see apps that handle web URLs
            (some delivery apps use deep links via https:// scheme).

         NOTE: We deliberately do NOT use <package> entries for each of the 169
         delivery platforms because:
           (a) it would be a maintenance burden (169 lines)
           (b) Play Store reviews <package> queries more strictly than <intent>
           (c) the <intent> LAUNCHER query covers all cases we need

         This is the Android-recommended approach for apps that need to launch
         other apps by package name:
         https://developer.android.com/training/package-visibility
         ═══════════════════════════════════════════════════════════════════════ -->
    <queries>
        <!-- See apps with a launcher icon (covers getLaunchIntentForPackage) -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <!-- See apps that handle https:// deep links (some delivery apps use these) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!-- See apps that handle custom scheme deep links (e.g., zomato://, swiggy://) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="*" />
        </intent>
    </queries>

    <application
        android:name=".NotiFetchApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NotiFetch"
        tools:targetApi="35">

        <!-- Remove AdServices config injected by Firebase Analytics -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            tools:node="remove" />
        <uses-library
            android:name="android.ext.adservices"
            tools:node="remove" />

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.NotiFetch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link from web → app (notifetch.in URLs) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.notifetch.in" />
                <data android:scheme="https" android:host="notifetch.in" />
            </intent-filter>
            <!-- Custom scheme deep link (fallback) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="notifetch" />
            </intent-filter>
        </activity>

        <!-- Notification Listener Service
             v2.9.6: Removed foregroundServiceType="specialUse" — it was set but
             startForeground() was never called, which causes:
               1. Android 14+ to refuse to start the service
               2. Play Store policy warnings about undeclared foreground service usage
             NotificationListenerService is a system-bound service (BIND_NOTIFICATION_LISTENER_SERVICE),
             it does NOT need to be a foreground service. The system keeps it alive
             automatically as long as the user has granted notification access.
        -->
        <service
            android:name=".notification.NotiFetchListenerService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <!-- FIX: Removed default_filter_types and default_rule_types metadata.
                 These OEM-specific metadata values were causing inconsistent behavior:
                 - On some Samsung/Xiaomi devices, they restricted which notifications the listener received
                 - Users reported only Zomato notifications appearing, not other apps
                 - The pipe-separated syntax (conversations|alerting|ongoing|silent) is not universally supported
                 - Some OEMs ignore these entirely and use their own filtering logic

                 By removing these metadata entries, the listener will receive ALL notifications
                 and filter programmatically in onNotificationPosted() against Constants.ALL_PACKAGES.
                 This ensures consistent behavior across all Android devices and OEMs.
            -->
        </service>

        <!-- v2.9.66: KeepAliveService — started from MainActivity (foreground context).
             v2.9.23 removed this due to crash; v2.9.66 fixes the crash root cause. -->
        <service
            android:name=".notification.KeepAliveService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Continuous notification monitoring for delivery aggregations" />
        </service>

        <!-- Firebase Messaging Service -->
        <service
            android:name=".firebase.NotiFetchMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- v2.9.9: Boot Receiver — auto-reconnect notification listener after device restart.
             Many OEM ROMs (Xiaomi/MIUI, OPPO, Vivo, Samsung) don't auto-reconnect
             NotificationListenerService after reboot unless the user opens the app.
             This receiver forces reconnection on boot. -->
        <receiver
            android:name=".notification.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- v2.9.12: Home Screen Widget — shows latest 3 notifications -->
        <receiver
            android:name=".widget.NotiFetchWidgetProvider"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.notifetch.app.REFRESH_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/notifetch_widget_info" />
        </receiver>

        <!-- WorkManager initialization -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
