generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  emailVerified DateTime?
  phoneVerified DateTime?
  image         String?
  passwordHash  String?
  region        String    @default("north-america")
  currency      String    @default("USD")
  language      String    @default("en")
  distanceUnit  String    @default("mi")
  role          String    @default("driver") // driver, admin
  plan          String    @default("free") // free, premium
  stripeCustomerId String?
  trialEndsAt   DateTime?
  fcmToken      String?
  rideSafeMode  Boolean   @default(false)
  soundAlerts   Boolean   @default(true)
  vibration     Boolean   @default(true)
  voiceAlerts   Boolean   @default(false)
  autoAccept    Boolean   @default(false)
  minValue      Float     @default(8.0)
  maxDistance   Float     @default(6.0)
  darkMode      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  connections   PlatformConnection[]
  orders        AcceptedOrder[]
  earnings      EarningRecord[]
  payments      Payment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // oauth, credentials
  provider          String  // google, credentials
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Platform Connections ─────────────────────────────────────────────────────

model PlatformConnection {
  id                String   @id @default(cuid())
  userId            String
  platformId        String   // uber-eats, doordash, etc.
  platformName      String
  category          String   // food, grocery, package, etc.
  connected         Boolean  @default(false)
  accessToken       String?  // encrypted OAuth token
  refreshToken      String?
  tokenExpiresAt    DateTime?
  notificationsToday Int     @default(0)
  earningsToday     Float    @default(0)
  lastSyncAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model AcceptedOrder {
  id            String   @id @default(cuid())
  userId        String
  platformId    String
  category      String
  value         Float
  currency      String   @default("USD")
  pickup        String
  dropoff       String
  distance      Float
  distanceUnit  String   @default("mi")
  status        String   @default("accepted") // accepted, completed, cancelled
  acceptedAt    DateTime @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Earnings ─────────────────────────────────────────────────────────────────

model EarningRecord {
  id          String   @id @default(cuid())
  userId      String
  platformId  String
  category    String
  amount      Float
  currency    String   @default("USD")
  date        DateTime
  orderCount  Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                  String   @id @default(cuid())
  userId              String
  stripePaymentId     String?
  razorpayPaymentId   String?
  amount              Float
  currency            String   @default("USD")
  status              String   @default("pending") // pending, completed, failed, refunded
  plan                String   // premium
  period              String   @default("monthly") // monthly, yearly
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notification Log ─────────────────────────────────────────────────────────

model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?
  platformId  String
  category    String
  title       String
  body        String
  value       Float?
  currency    String?
  sentAt      DateTime @default(now())
  deliveredAt DateTime?
  openedAt    DateTime?
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}
