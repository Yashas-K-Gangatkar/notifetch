# ─── Required for Vercel Deployment ───────────────────────────────────────────
# Copy this file to .env and fill in the values.
# These MUST be set in Vercel Dashboard → Settings → Environment Variables.

# PostgreSQL database URL (use Neon, Supabase, or Vercel Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here

# NextAuth URL (your Vercel deployment URL)
NEXTAUTH_URL=https://d2-liart-nine.vercel.app

# ─── Optional (enable features when set) ─────────────────────────────────────

# Google OAuth (for web sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Firebase Admin (for push notifications)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Firebase Client (for browser FCM)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Email (Resend API for OTP)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=NotiFetch <noreply@yourdomain.com>

# Razorpay Payments
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Stripe Payments
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
