# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/
db/custom.db

# TWA / Android build artifacts
twa/keystore.jks
twa/signing-credentials.txt
twa/.gradle/
twa/app/build/
twa/build/
twa/temp-icon/

# Android secrets
google-services.json
**/google-services.json
*.jks
*.keystore
# Signing credentials — NEVER commit (contains keystore passwords)
**/keystore.properties
**/signing.properties
tool-results/
# Download directory - build outputs
download/*.apk
download/*.aab
download/crashlytics-mapping-*.txt

# Build artifacts
**/build/
**/.gradle/

# JDK (too large for git)
/jdk/
/jdk21/
/jdk-*/
# Auth service — separate repo, not tracked as submodule
notifetch-auth/
upload/client_secret*
upload/google-services*
upload/Pasted*
# Build artifacts
notifetch-android/*.aab
notifetch-android/app/build/
notifetch-android/.gradle/
notifetch-android/local.properties
.env.local
